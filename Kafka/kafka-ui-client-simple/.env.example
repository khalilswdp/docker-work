# Comma-separated bootstrap servers, same as IntelliJ Big Data Tools
KAFKA_BOOTSTRAP_SERVERS=broker1.example.com:9093,broker2.example.com:9093,broker3.example.com:9093

# Kafka SASL/PLAIN credentials
KAFKA_USERNAME=token
KAFKA_PASSWORD=replace-me

# JKS files are mounted from ./certs to /certs inside kafka-ui
KAFKA_TRUSTSTORE_PASSWORD=replace-me
KAFKA_KEYSTORE_PASSWORD=replace-me
KAFKA_KEY_PASSWORD=replace-me

# Confluent Schema Registry with Basic Auth
SCHEMA_REGISTRY_URL=https://schema-registry.example.com:4201
SCHEMA_REGISTRY_USERNAME=token
SCHEMA_REGISTRY_PASSWORD=replace-me
